# Backend provider: 'memory' (mock, local dev) or 'microsoft365' (SharePoint lists)
REPORTS_BACKEND_PROVIDER=memory

AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000
AUTH_SECRET=
# Optional fallback admin allowlist. If the Employees list is configured,
# users with matching Email + IsAdmin=true are treated as admins automatically.
AUTH_ADMIN_EMAILS=
# Optional when Auth.js uses the same Entra app registration as the backend.
# If left empty, auth.ts falls back to MICROSOFT365_CLIENT_ID and MICROSOFT365_CLIENT_SECRET.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Full issuer URL, for example: https://login.microsoftonline.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

MICROSOFT365_TENANT_ID=
MICROSOFT365_CLIENT_ID=
MICROSOFT365_CLIENT_SECRET=
MICROSOFT365_SHAREPOINT_HOSTNAME=
MICROSOFT365_SHAREPOINT_SITE_PATH=
MICROSOFT365_SITE_ID=
# Weekly report visits list (required with the microsoft365 provider)
MICROSOFT365_VISITS_LIST_ID=
# Optional employee registry used to flag admins (IsAdmin=Yes)
MICROSOFT365_EMPLOYEES_LIST_ID=

# Client directory ("cliente visitato" search) — Skyline ERP (Oracle 11g).
# Queried through the 32-bit Oracle ODBC driver via 32-bit PowerShell.
# Free-text client names are always allowed, so this only powers autocomplete.
ORACLE_USER=
ORACLE_PASSWORD=
# EZConnect used as the ODBC DBQ: host:port/service
ORACLE_CONNECT_STRING=
# Schema that owns ANAGRAFICO_CONTI / CONTI_CLIENTI
ORACLE_OWNER=
# Optional overrides (defaults shown):
# ORACLE_ODBC_DRIVER=Oracle in OraClient11g_home1_32bit
# ORACLE_POWERSHELL_32=C:\Windows\SysWOW64\WindowsPowerShell\v1.0\powershell.exe
